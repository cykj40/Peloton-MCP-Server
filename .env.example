# Credentials for automatic JWT authentication (RECOMMENDED)
# The server will automatically log in and manage JWT tokens
PELOTON_USERNAME=your_username
PELOTON_PASSWORD=your_password

# Manual Bearer token (optional, for manual auth if credentials not provided)
# Get from browser DevTools > Network tab > Authorization header
# Log into members.onepeloton.com, refresh, click any api.onepeloton.com request,
# copy the token after "Bearer " in the Authorization header
PELOTON_BEARER_TOKEN=your_bearer_token_here

# Legacy session cookie (optional fallback, generally not needed with JWT)
# Use peloton_refresh_cookie tool instead of manually setting this
PELOTON_SESSION_COOKIE=your_session_cookie_here

# Database path for storing workouts and glucose correlations
PELOTON_DB_PATH=./data/peloton.db
