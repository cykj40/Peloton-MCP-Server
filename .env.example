# Bearer token (preferred): Get from browser DevTools > Network tab > Authorization header
# Log into members.onepeloton.com, refresh, click any api.onepeloton.com request,
# copy the token after "Bearer " in the Authorization header
PELOTON_BEARER_TOKEN=your_bearer_token_here

# Legacy session cookie (fallback if bearer token not set)
PELOTON_SESSION_COOKIE=your_session_cookie_here

# Optional: Credentials (note: Peloton may block /auth/login)
PELOTON_USERNAME=your_username
PELOTON_PASSWORD=your_password

# Database path for storing workouts and glucose correlations
PELOTON_DB_PATH=./data/peloton.db
